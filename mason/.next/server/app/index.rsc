3:["$","main",null,{"className":"pt-20","children":[["$","$L11",null,{"hero":{"_createdAt":"2026-02-16T19:55:09Z","_id":"b939ccd9-f273-4dbc-87fa-3af4a1f32bbd","_rev":"EiL0uGXRw6rhIfqfpxPKVA","_system":{"base":{"id":"b939ccd9-f273-4dbc-87fa-3af4a1f32bbd","rev":"4uLYs44Bnpx4MVF3UCsEeO"}},"_type":"hero","_updatedAt":"2026-02-27T21:25:47Z","backgroundImage":{"_type":"image","asset":{"_ref":"image-5ca6b7da8d17e96dfaa54b5f7031951d77165f6b-1200x600-webp","_type":"reference"}},"ctaLink":"/contact","ctaText":"Get Your Free Quote","heading":"Restoring History, One Piece at a Time","subheading":"Expert restoration for Masonic plaques, presentation pieces, and ceremonial paraphernalia"}}],["$","div",null,{"id":"services","children":["$","$L12",null,{"services":[{"_createdAt":"2026-02-16T19:59:51Z","_id":"93d4fbfd-8266-48fb-ac4d-87a6bcab8e54","_rev":"1KjNhVUscwCwiDwpK2qMq2","_type":"service","_updatedAt":"2026-02-16T20:00:12Z","description":" We restore metal plaques of all sizes, removing tarnish, repairing damage, and restoring original finishes. From cornerstone plaques to memorial dedications, we bring them back to their former glory.","order":10,"title":"Plaque Restoration"},{"_createdAt":"2026-02-16T20:00:12Z","_id":"a0917cf6-9ed0-4e11-b92b-29bdc8ca5984","_rev":"RPhAsU9kvVWGOkUO7ILxQG","_type":"service","_updatedAt":"2026-02-16T20:00:25Z","description":"Gavels, trowels, squares, and compasses—we restore all ceremonial presentation items. Our process preserves engravings while renewing the finish and structural integrity.","order":20,"title":"Presentation Pieces"},{"_createdAt":"2026-02-16T20:00:30Z","_id":"45086044-20f4-467a-8d18-32b25d582ec5","_rev":"1KjNhVUscwCwiDwpK2qTKG","_type":"service","_updatedAt":"2026-02-16T20:01:12Z","description":"We carefully clean and restore Masonic medals, jewels, and regalia items. Each piece is handled with care to preserve delicate details and historical significance.","order":30,"title":"Medal & Regalia Restoration"},{"_createdAt":"2026-02-16T20:00:50Z","_id":"16cd3187-b88a-488d-adb1-26e21dbb8fef","_rev":"DZcaT4EDJXJnYMa8SQTLNZ","_type":"service","_updatedAt":"2026-02-16T20:01:09Z","description":" Add personalized engravings to restored or new items. We match historical fonts and styles or create custom designs for new presentations.","order":40,"title":"Custom Engraving"}]}]}],["$","div",null,{"id":"gallery","children":false}],["$","div",null,{"id":"testimonials","children":false}],["$","$L13",null,{"settings":{"_createdAt":"2026-02-16T19:57:55Z","_id":"061c6aff-56a0-4017-8cc6-8f004c9ec105","_rev":"1KjNhVUscwCwiDwpK2qbVW","_system":{"base":{"id":"061c6aff-56a0-4017-8cc6-8f004c9ec105","rev":"RPhAsU9kvVWGOkUO7IN1ZQ"}},"_type":"siteSettings","_updatedAt":"2026-02-16T20:03:56Z","aboutSection":{"content":[{"_key":"498df9cc6f29","_type":"block","children":[{"_key":"9f5d128fae39","_type":"span","marks":[],"text":"For over 25 years, Heritage Restoration Services has been the trusted choice for lodges and collectors seeking to preserve their most cherished Masonic items.\nWhat started as a passion project in a small workshop has grown into a full-service restoration studio, serving lodges and collectors across the region. Our founder, a third-generation craftsman and proud Mason, understood that these items are more than objects—they're connections to history, tradition, and brotherhood.\nEvery plaque, medal, and presentation piece that comes through our doors carries a story. Whether it's a tarnished cornerstone plaque from 1892 or a presentation gavel that's lost its luster, we treat each item with the reverence it deserves.\nOur team combines time-honored restoration techniques with modern precision tools to deliver results that honor the past while ensuring durability for future generations."}],"markDefs":[],"style":"normal"}],"heading":"Our Story"},"address":"123 Craftsman Lane\nplace place \nscotland, BT-Something\n","description":"We specialize in the expert restoration of Masonic plaques, presentation pieces, and ceremonial paraphernalia. Our craftspeople honor traditional techniques while bringing new life to your treasured items.","email":"info@heritagerestoration.com","phone":"07856455363","siteName":"Heritage Restoration Services","tagline":"Preserving Masonic Legacy Since 1995"}}],"$L14"]}]
