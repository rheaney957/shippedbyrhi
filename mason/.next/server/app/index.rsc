2:["$","html",null,{"lang":"en","className":"scroll-smooth","children":["$","body",null,{"className":"inter_5972bc34-module__OU16Qa__className","children":[["$","$Lc",null,{"settings":{"_createdAt":"2026-02-16T19:57:55Z","_id":"061c6aff-56a0-4017-8cc6-8f004c9ec105","_rev":"1KjNhVUscwCwiDwpK2qbVW","_system":{"base":{"id":"061c6aff-56a0-4017-8cc6-8f004c9ec105","rev":"RPhAsU9kvVWGOkUO7IN1ZQ"}},"_type":"siteSettings","_updatedAt":"2026-02-16T20:03:56Z","aboutSection":{"content":[{"_key":"498df9cc6f29","_type":"block","children":[{"_key":"9f5d128fae39","_type":"span","marks":[],"text":"For over 25 years, Heritage Restoration Services has been the trusted choice for lodges and collectors seeking to preserve their most cherished Masonic items.\nWhat started as a passion project in a small workshop has grown into a full-service restoration studio, serving lodges and collectors across the region. Our founder, a third-generation craftsman and proud Mason, understood that these items are more than objects—they're connections to history, tradition, and brotherhood.\nEvery plaque, medal, and presentation piece that comes through our doors carries a story. Whether it's a tarnished cornerstone plaque from 1892 or a presentation gavel that's lost its luster, we treat each item with the reverence it deserves.\nOur team combines time-honored restoration techniques with modern precision tools to deliver results that honor the past while ensuring durability for future generations."}],"markDefs":[],"style":"normal"}],"heading":"Our Story"},"address":"123 Craftsman Lane\nplace place \nscotland, BT-Something\n","description":"We specialize in the expert restoration of Masonic plaques, presentation pieces, and ceremonial paraphernalia. Our craftspeople honor traditional techniques while bringing new life to your treasured items.","email":"info@heritagerestoration.com","phone":"07856455363","siteName":"Heritage Restoration Services","tagline":"Preserving Masonic Legacy Since 1995"}}],["$","$Ld",null,{"parallelRouterKey":"children","error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$Le",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[["$","main",null,{"className":"min-h-screen flex items-center justify-center bg-gray-50 pt-20","children":["$","div",null,{"className":"text-center px-4","children":[["$","h1",null,{"className":"text-6xl font-bold text-gray-900 mb-4","children":"404"}],["$","h2",null,{"className":"text-3xl font-bold text-gray-700 mb-4","children":"Page Not Found"}],["$","p",null,{"className":"text-xl text-gray-600 mb-8","children":"Sorry, we couldn't find the page you're looking for."}],["$","$Lf",null,{"href":"/","className":"inline-block bg-amber-600 hover:bg-amber-700 text-white font-semibold px-8 py-3 rounded-lg transition-colors duration-200","children":"Go Home"}]]}]}],[]],"forbidden":"$undefined","unauthorized":"$undefined"}],["$","$L10",null,{"settings":"$2:props:children:props:children:0:props:settings"}]]}]}]
