ing\n","description":"We specialize in the expert restoration of Masonic plaques, presentation pieces, and ceremonial paraphernalia. Our craftspeople honor traditional techniques while bringing new life to your treasured items.","email":"info@heritagerestoration.com","phone":"07856455363","siteName":"Heritage Restoration Services","tagline":"Preserving Masonic Legacy Since 1995"}}],["$","section",null,{"className":"py-20 bg-gray-50","children":["$","div",null,{"className":"container mx-auto px-4","children":[["$","div",null,{"className":"text-center mb-16","children":["$","h2",null,{"className":"text-4xl md:text-5xl font-bold text-gray-900 mb-4","children":"Our Values"}]}],["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto","children":[["$","div",null,{"className":"text-center p-8 bg-white rounded-lg shadow-md","children":[["$","div",null,{"className":"w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-4","children":["$","svg",null,{"className":"w-8 h-8 text-amber-600","fill":"none","stroke":"currentColor","viewBox":"0 0 24 24","children":["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","strokeWidth":2,"d":"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"}]}]}],["$","h3",null,{"className":"text-2xl font-bold text-gray-900 mb-3","children":"Quality"}],["$","p",null,{"className":"text-gray-600","children":"We never compromise on the quality of our work. Every piece receives meticulous attention to detail."}]]}],["$","div",null,{"className":"text-center p-8 bg-white rounded-lg shadow-md","children":[["$","div",null,{"className":"w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-4","children":["$","svg",null,{"className":"w-8 h-8 text-amber-600","fill":"none","stroke":"currentColor","viewBox":"0 0 24 24","children":["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","strokeWidth":2,"d":"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"}]}]}],"$L3","$L4